# JWT – generiere einen sicheren Wert mit: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=67bf2b7759a931f37fb99dd2b471893f840a6fa13c1022cdea8aa5e1729e2742

# CORS – Origins als JSON-Array
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

SENTRY_DSN=

# Basis-URL für QR-Codes
BASE_URL=http://localhost:8050

# MinIO – Objektspeicher für Gerätebilder
# generiere sichere Werte mit: python -c "import secrets; print(secrets.token_hex(32))"
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=geraete-bilder
# Öffentlich erreichbare MinIO-Adresse (für Presigned-URLs im Browser)
# Lokal:    localhost:9002
# Server:   minio.deinedomain.de  oder  deine-server-ip:9002
MINIO_PUBLIC_ENDPOINT=localhost:9002
MINIO_BROWSER_REDIRECT_URL=
MINIO_SERVER_URL=